# ---- Environment selection -------------------------------------------------
# dev  -> UGetFirst-dev project (safe test data)
# prod -> UGetFirst project (real subscribers)
ENV=dev

# ---- Supabase: Prod --------------------------------------------------------
PROD_SUPABASE_URL=
PROD_SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase: Dev ---------------------------------------------------------
DEV_SUPABASE_URL=
DEV_SUPABASE_SERVICE_ROLE_KEY=

# ---- Prod Postgres (Auth sync password hashes) -----------------------------
# Required for scripts/sync_prod_to_dev.py --apply (reads auth.users).
# Dashboard → Database → Connection string (URI). Prefer Session pooler.
PROD_DATABASE_URL=

# ---- Apify -----------------------------------------------------------------
APIFY_TOKEN=
APIFY_ACTOR_ID=apify/facebook-groups-scraper

# ---- Twilio ----------------------------------------------------------------
# SMS_MODE=twilio when creds are set; otherwise simulated outbox.
SMS_MODE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# DEV live-send allowlist. Only these destinations may call providers in DEV;
# all other DEV alerts are written to outbox/. Ignored when ENV=prod.
QA_TEST_EMAIL=
QA_TEST_PHONE=
# Max SMS per subscriber per engine cycle (0 = unlimited).
SMS_MAX_PER_SUBSCRIBER_PER_CYCLE=5
# Milliseconds between sends in a cycle (Twilio 429 cushion). 0 = no delay.
SMS_SEND_DELAY_MS=250

# ---- Loop / scrape tuning --------------------------------------------------
# Global tick (Lightning). Per-group due filter uses POLL_*_SECONDS.
MIN_INTERVAL_SECONDS=600
POLL_FREE_SECONDS=1800
POLL_SPEED_SECONDS=1200
POLL_LIGHTNING_SECONDS=600
LOOKBACK_BUFFER_MINUTES=10
# Fallback lookback when cycle does not override; keep >= slowest poll + buffer.
LOOKBACK=40 minutes
# Max posts per group per scrape (safety cap).
RESULTS_LIMIT=20
RESULTS_PER_GROUP=10
SCRAPE_BATCH_SIZE=25
APIFY_MAX_RETRIES=1

# ---- Email match alerts (Resend) -------------------------------------------
# When unset, emails are written to outbox/email_*.txt
RESEND_API_KEY=
ALERT_FROM_EMAIL=UGetFirst <alerts@ugetfirst.com>
