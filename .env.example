# ---- Environment selection -------------------------------------------------
# dev  -> UGetFirst-dev project (safe test data)
# prod -> UGetFirst project (real subscribers)
ENV=dev

# ---- Supabase: Prod --------------------------------------------------------
PROD_SUPABASE_URL=
PROD_SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase: Dev ---------------------------------------------------------
DEV_SUPABASE_URL=
DEV_SUPABASE_SERVICE_ROLE_KEY=

# ---- Apify -----------------------------------------------------------------
APIFY_TOKEN=
APIFY_ACTOR_ID=apify/facebook-groups-scraper

# ---- Twilio ----------------------------------------------------------------
# SMS_MODE=twilio when creds are set; otherwise simulated outbox.
SMS_MODE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Loop / scrape tuning --------------------------------------------------
# Minimum seconds between the START of consecutive cycles.
MIN_INTERVAL_SECONDS=600
# Scrape window for Apify onlyPostsNewerThan. Keep >= poll interval + buffer
# so posts between cycles are not missed (dedup handles overlaps).
LOOKBACK=30 minutes
# Max posts per group per scrape (safety cap).
RESULTS_LIMIT=20
RESULTS_PER_GROUP=10
SCRAPE_BATCH_SIZE=25
APIFY_MAX_RETRIES=1
